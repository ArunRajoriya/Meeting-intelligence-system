# Meeting Intelligence System - Environment Variables
# Copy this file to .env and add your actual API keys

# Required: Groq API Key
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Transcription Providers
# Uncomment and add the provider you want to use

# OpenAI Whisper API (recommended for production)
# Get key from: https://platform.openai.com/api-keys
# Cost: ~$0.006 per minute
# OPENAI_API_KEY=your_openai_key_here

# AssemblyAI (free tier available)
# Get key from: https://www.assemblyai.com/
# ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# Note: Local Whisper doesn't need an API key
# Just install: pip install openai-whisper
# And install FFmpeg: https://ffmpeg.org

# Optional: Model Configuration
# Uncomment to override defaults

# Whisper model (for Groq)
# WHISPER_MODEL=whisper-large-v3-turbo

# LLaMA model (for analysis) - Updated to current model
# LLAMA_MODEL=llama-3.3-70b-versatile
